import bisect

class Solution(object):
    def searchRange(self, nums, target):
        """
        :type nums: List[int]
        :type target: int
        :rtype: List[int]
        """
        low=bisect_left(nums,target)
        high=bisect_right(nums,target)-1

        if low<=high:
            return [low,high]
            
        return [-1,-1]


        
