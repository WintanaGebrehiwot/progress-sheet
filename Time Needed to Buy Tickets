class Solution(object):
    def timeRequiredToBuy(self, tickets, k):
        """
        :type tickets: List[int]
        :type k: int
        :rtype: int
        """
        count = 0
        n = len(tickets)
        
        while tickets[k] > 0:
            for i in range(n):
                if tickets[i] > 0:  
                    tickets[i] -= 1  
                    count += 1       
                if tickets[k] == 0:  
                    break
        return count
