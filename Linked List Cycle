# Definition for singly-linked list.
# class ListNode(object):
#     def __init__(self, x):
#         self.val = x
#         self.next = None

class Solution(object):
    def hasCycle(self, head):
        """
        :type head: ListNode
        :rtype: bool
        """
        slow,fast=head,head
        is_cycle=False

        while fast and fast.next:
            slow=slow.next
            fast=fast.next.next

            if slow==fast:
                is_cycle=True
                return True

        if not is_cycle:
                return False
