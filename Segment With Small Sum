n, s = map(int, input().split())
num = list(map(int, input().split()))
 
left = 0
max_len = 0
window_sum = 0
 
for right in range(n):
    window_sum += num[right]
 
    while window_sum > s:
        window_sum -= num[left]  
        left += 1
 
    max_len = max(max_len, right - left + 1)
 
print(max_len)
