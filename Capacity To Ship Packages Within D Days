class Solution(object):
    def shipWithinDays(self, weights, days):
        """
        :type weights: List[int]
        :type days: int
        :rtype: int
        """
        def is_cap(mid):
            tot=0
            count=1
            for weight in weights:
                if tot+weight>mid:
                    count+=1
                    tot=0
                tot+=weight

            return count<=days

        low, high=max(weights), sum(weights)

        while low <= high:
            mid=(low+high)//2

            if is_cap(mid):
                high=mid-1
            else:
                low=mid+1

        return low

